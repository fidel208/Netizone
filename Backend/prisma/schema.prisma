// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  password     String
  email        String   @unique
  phoneNumber  String
  internetName String   @unique
  isApproved   Boolean  @default(false)
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  routers Router[]
  pools   Pool[]
}

model Router {
  id        String   @id @default(uuid())
  name      String   @unique
  ipAddress String   @unique
  username  String
  secret    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  packages Package[]
  ipPools  Pool[]
}

model Package {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  type      String   @default("prepaid")
  price     Float    @default(0.0)
  limitType String   @default("unlimited")
  bandwidth String
  validity  String
  timeLimit String   @default("Unlimited")
  dataLimit String   @default("Unlimited")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  router   Router? @relation(fields: [routerId], references: [id])
  routerId String?
}

model Pool {
  id        String   @id @default(uuid())
  name      String   @unique
  rangeIp   String   @unique
  createdAt DateTime @default(now())

  routerId String?
  router   Router? @relation(fields: [routerId], references: [id])
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
